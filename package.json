{
  "name": "cloudctf",
  "version": "1.0.0",
  "private": true,
  "description": "A full CTF platform (CTFd-style) running entirely on Cloudflare Workers + D1 + KV + R2",
  "type": "module",
  "scripts": {
    "dev:web": "vite",
    "dev": "wrangler dev",
    "build": "vite build",
    "typecheck": "tsc -p tsconfig.json && tsc -p web/tsconfig.json",
    "deploy": "vite build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply cloudctf --local",
    "db:migrate": "wrangler d1 migrations apply cloudctf --remote"
  },
  "dependencies": {
    "dompurify": "^3.4.10",
    "hono": "^4.6.14",
    "marked": "^18.0.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250601.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/react-query": "^5.62.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "recharts": "^2.15.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "wrangler": "^4.100.0"
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "esbuild@0.27.3": true,
    "workerd@1.20260611.1": true,
    "sharp@0.34.5": true
  }
}
